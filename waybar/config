{
  "layer": "bottom",
  "position": "top",
  "height": 20,
  "spacing": 8,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "battery", "tray", "network"],

  "clock": {
    "format": "{:%I:%M — %d/%m/%y}"
  },

  "cpu": {
    "format": "CPU {usage}%"
  },

  "memory": {
    "format": "RAM {used:0.1f}G"
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUTED"
  },

  "network": {
    "format-wifi": "{essid}",
    "format-ethernet": "ETH",
    "format-disconnected": "NO NET"
  },

  "battery": {
    "format": "{capacity}%",
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format-charging": "CHR {capacity}%",
    "format-discharging": "BAT {capacity}%",
    "format-full": "FULL"
  }
}

